# ============================================================
# 錄音檔摘要機器人（免費版）— 設定範本
# 複製此檔為 .env 並填入金鑰
# 費用：完全免費 $0
# ============================================================

# ── Groq 免費 API（必填）──────────────────────────────────
# 申請免費金鑰（1分鐘完成）：https://console.groq.com/keys
# 每日免費額度充足，不需要信用卡
GROQ_API_KEY=gsk_...
# 使用的模型（免費且性能強）
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Drive（必填）───────────────────────────────────
# 服務帳號 JSON 金鑰檔路徑（跟 audio_summary_bot.py 放同一資料夾）
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# 要掃描的資料夾 ID，多個用逗號分隔，留空或填 root = 掃描整個雲端硬碟
# 資料夾 ID 從 Google Drive URL 取得：
#   https://drive.google.com/drive/folders/【這段就是 ID】
#
# 範例（一個資料夾）：
# GOOGLE_DRIVE_FOLDER_IDS=ABC123xyzFolderID
#
# 範例（多個資料夾，用逗號分隔）：
# GOOGLE_DRIVE_FOLDER_IDS=ABC123xyzFolderID,DEF456uvwFolderID,GHI789rstFolderID
GOOGLE_DRIVE_FOLDER_IDS=root

# ── Notion（必填）──────────────────────────────────────────
# Integration Token：https://www.notion.so/my-integrations（免費）
NOTION_TOKEN=secret_...
# 「錄音檔摘要」資料庫 ID（從資料庫 URL 的 32 碼取得）
NOTION_DATABASE_ID=

# ── GitHub（選填，推送 Markdown 備份到 repo）──────────────
# Personal Access Token（repo 權限）：
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
# 你的 GitHub repo（格式：帳號/倉庫名稱）
GITHUB_REPO=your-username/audio-summaries
GITHUB_BRANCH=main
GITHUB_FOLDER=audio-summaries

# ── Whisper 模型選擇 ────────────────────────────────────────
# tiny   = 最快（準確度低，適合測試）
# base   = 快速（基本準確）
# small  = 推薦（速度與準確度平衡）← GitHub Actions 預設
# medium = 準確（較慢）
# large-v3 = 最準確（本機 GPU 才建議用）
WHISPER_MODEL=small
# 語言提示（zh=中文；留空=自動偵測）
WHISPER_LANGUAGE=zh

# ── 其他 ────────────────────────────────────────────────────
PROCESSED_CACHE=processed_files.json
SUMMARY_LANGUAGE=繁體中文
